APP_ENV=local
APP_DEBUG=true

# Databases (Shared instance with service-specific schemas)
DB_HOST=mysql
DB_USERNAME=root
DB_PASSWORD=
DB_PORT=3306

# Redis (Event bus, Session cache, JWT blacklist)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Config (HS256)
JWT_SECRET=super-secure-lgbtq-matrimony-secret-key-123456
JWT_ACCESS_EXPIRY=900 # 15 minutes (in seconds)
JWT_REFRESH_EXPIRY=604800 # 7 days (in seconds)

# Payment Gateways (Stripe & Razorpay)
STRIPE_KEY=pk_test_mock_stripe_key_51O
STRIPE_SECRET=sk_test_mock_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_mock_webhook_secret
RAZORPAY_KEY_ID=rzp_test_mock_key_id
RAZORPAY_KEY_SECRET=mock_razorpay_key_secret

# Real-time WebSocket
WS_PORT=8080
WS_URL=ws://localhost/ws/

# Notifications (Mock SMTP / FCM)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM_ADDRESS=noreply@lgbtqmatrimony.local
MAIL_FROM_NAME="LGBTQ+ Matrimony"
FIREBASE_FCM_SECRET=mock-firebase-fcm-server-secret-key
